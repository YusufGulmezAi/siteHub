@* MainLayout.razor — AdminLTE-inspired dark sidebar layout *@
@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject SiteHub.Application.Abstractions.Context.ICurrentUser CurrentUser

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="sitehub-layout">

    @* ─── TOP APP BAR ─────────────────────────────────────────── *@
    <MudAppBar Elevation="1" Color="Color.Inherit" Class="sitehub-appbar">
        <MudIconButton
            Icon="@Icons.Material.Filled.Menu"
            Color="Color.Default"
            Edge="Edge.Start"
            OnClick="ToggleDrawer" />

        <MudText Typo="Typo.h6" Class="mx-3 d-none d-md-block">SiteHub</MudText>

        <ContextSwitcher OnContextChanged="OnContextChanged" />

        <MudSpacer />

        <MudTooltip Text="Bildirimler">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Default" />
        </MudTooltip>

        <MudTooltip Text="@(_isDarkMode ? "Açık tema" : "Koyu tema")">
            <MudIconButton
                Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                Color="Color.Default"
                OnClick="@(() => _isDarkMode = !_isDarkMode)" />
        </MudTooltip>

        @* Avatar + manuel dropdown (MudMenu yerine MudPopover — v9'da MudMenu Blazor Server'da sorunlu) *@
        <div class="user-menu-wrapper">
            <MudAvatar Color="Color.Primary"
                       Size="Size.Small"
                       Class="ml-2 user-menu-activator"
                       @onclick="ToggleUserMenu">@CurrentUser.Initials</MudAvatar>

            <MudPopover Open="@_userMenuOpen"
                        AnchorOrigin="Origin.BottomRight"
                        TransformOrigin="Origin.TopRight"
                        Paper="true"
                        Class="user-menu-popover mt-2">
                <div class="user-menu-header">
                    <MudAvatar Color="Color.Primary" Size="Size.Medium">@CurrentUser.Initials</MudAvatar>
                    <div class="user-menu-header-info">
                        <div class="user-menu-name">@(CurrentUser.FullName ?? "Misafir")</div>
                        <div class="user-menu-email">@(CurrentUser.Email ?? "-")</div>
                    </div>
                </div>

                <MudDivider />

                <div class="user-menu-items">
                    <button class="user-menu-item" @onclick="CloseUserMenu">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        <span>Profilim</span>
                    </button>
                    <button class="user-menu-item" @onclick="NavigateToTwoFactor">
                        <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small" />
                        <span>Güvenlik (2FA)</span>
                    </button>
                </div>

                <MudDivider />

                <div class="user-menu-items">
                    <button class="user-menu-item user-menu-item-danger" @onclick="HandleLogout">
                        <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" />
                        <span>Çıkış Yap</span>
                    </button>
                </div>
            </MudPopover>
        </div>

        @* Menu d\u0131\u015f\u0131na t\u0131klan\u0131nca kapans\u0131n *@
        @if (_userMenuOpen)
        {
            <MudOverlay Visible="true"
                        OnClick="CloseUserMenu"
                        ZIndex="1200"
                        DarkBackground="false" />
        }
    </MudAppBar>

    @* ─── LEFT DRAWER (koyu sidebar, AdminLTE tarzı) ─────────── *@
    <MudDrawer
        @bind-Open="_drawerOpen"
        ClipMode="DrawerClipMode.Always"
        Elevation="0"
        Variant="DrawerVariant.Persistent"
        Class="sitehub-sidebar"
        Width="260px">

        <div class="sidebar-brand">
            <MudIcon Icon="@Icons.Material.Filled.Apartment" Class="brand-icon" />
            <div class="brand-text">
                <div class="brand-title">SiteHub</div>
                <div class="brand-subtitle">Yönetici Portalı</div>
            </div>
        </div>

        <NavigationMenu />

        <div class="sidebar-footer">
            <MudText Typo="Typo.caption" Style="opacity:0.6">v0.1.0 • Dev</MudText>
        </div>
    </MudDrawer>

    @* ─── MAIN CONTENT ─────────────────────────────────────────── *@
    <MudMainContent Class="sitehub-main">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _userMenuOpen;  // Avatar dropdown state

    // AdminLTE 4 renk paleti: koyu sidebar + açık içerik
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#2563EB",
            Secondary = "#0EA5E9",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#1F2937",
            DrawerBackground = "#1F2937",
            DrawerText = "#E5E7EB",
            DrawerIcon = "#9CA3AF",
            Background = "#F3F4F6",
            Surface = "#FFFFFF",
            TextPrimary = "#1F2937",
            TextSecondary = "#6B7280",
            Divider = "#E5E7EB"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#3B82F6",
            Secondary = "#06B6D4",
            AppbarBackground = "#0F172A",
            AppbarText = "#F1F5F9",
            DrawerBackground = "#0B1220",
            DrawerText = "#E2E8F0",
            DrawerIcon = "#94A3B8",
            Background = "#0F172A",
            Surface = "#1E293B"
        },
        LayoutProperties = new LayoutProperties { DefaultBorderRadius = "6px" }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void ToggleUserMenu() => _userMenuOpen = !_userMenuOpen;

    private void CloseUserMenu() => _userMenuOpen = false;

    private void NavigateToTwoFactor()
    {
        _userMenuOpen = false;
        Nav.NavigateTo("/account/security/2fa");
    }

    protected override void OnInitialized()
    {
        // Unauthenticated kullan\u0131c\u0131y\u0131 login'e yönlendir.
        // Normalde SessionValidationMiddleware bunu yap\u0131yor, ama ilk render'da
        // henüz middleware devreye girmemi\u015f olabilir — bu ikincil bir koruma.
        if (!CurrentUser.IsAuthenticated)
        {
            Nav.NavigateTo("/login", forceLoad: false);
        }
    }

    private void OnContextChanged(Services.Contexts.ContextItem ctx)
    {
        // İleride: URL'yi /c/{type}/{id}/... yap, menüleri permission'a göre yenile,
        // active context state'i güncelle, ilgili dashboard'a git.
        Nav.NavigateTo("/", forceLoad: false);
    }

    private async Task HandleLogout()
    {
        _userMenuOpen = false;

        // /auth/logout endpoint'ini fetch ile çağır — session Redis'ten silinir,
        // cookie'ler sunucu tarafından silinir. Sonrasında login sayfasına tam redirect.
        try
        {
            await JS.InvokeVoidAsync("sitehubAuth.logout");
        }
        catch
        {
            // Logout best-effort — hata olsa bile login'e yönlendir.
        }

        Nav.NavigateTo("/login", forceLoad: true);
    }
}
