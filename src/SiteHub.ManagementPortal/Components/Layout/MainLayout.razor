@* MainLayout.razor — AdminLTE-inspired dark sidebar layout *@
@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject IHttpContextAccessor HttpContextAccessor
@inject SiteHub.Application.Abstractions.Context.ICurrentUser CurrentUser
@inject SiteHub.ManagementPortal.Services.Authentication.IAuthenticationEventService AuthEvents

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="sitehub-layout">

    @* ─── TOP APP BAR ─────────────────────────────────────────── *@
    <MudAppBar Elevation="1" Color="Color.Inherit" Class="sitehub-appbar">
        <MudIconButton
            Icon="@Icons.Material.Filled.Menu"
            Color="Color.Default"
            Edge="Edge.Start"
            OnClick="ToggleDrawer" />

        <MudText Typo="Typo.h6" Class="mx-3 d-none d-md-block">SiteHub</MudText>

        <ContextSwitcher OnContextChanged="OnContextChanged" />

        <MudSpacer />

        <MudTooltip Text="Bildirimler">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Default" />
        </MudTooltip>

        <MudTooltip Text="@(_isDarkMode ? "Açık tema" : "Koyu tema")">
            <MudIconButton
                Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                Color="Color.Default"
                OnClick="@(() => _isDarkMode = !_isDarkMode)" />
        </MudTooltip>

        @* Avatar + manuel dropdown *@
        <div class="user-menu-wrapper">
            <MudAvatar Color="Color.Primary"
                       Size="Size.Small"
                       Class="ml-2 user-menu-activator"
                       @onclick="ToggleUserMenu">@CurrentUser.Initials</MudAvatar>

            <MudPopover Open="@_userMenuOpen"
                        AnchorOrigin="Origin.BottomRight"
                        TransformOrigin="Origin.TopRight"
                        Paper="true"
                        Class="user-menu-popover mt-2">
                <div class="user-menu-header">
                    <MudAvatar Color="Color.Primary" Size="Size.Medium">@CurrentUser.Initials</MudAvatar>
                    <div class="user-menu-header-info">
                        <div class="user-menu-name">@(CurrentUser.FullName ?? "Misafir")</div>
                        <div class="user-menu-email">@(CurrentUser.Email ?? "-")</div>
                    </div>
                </div>

                <MudDivider />

                <div class="user-menu-items">
                    <button class="user-menu-item" @onclick="CloseUserMenu">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        <span>Profilim</span>
                    </button>
                    <button class="user-menu-item" @onclick="NavigateToTwoFactor">
                        <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small" />
                        <span>Güvenlik (2FA)</span>
                    </button>
                </div>

                <MudDivider />

                <div class="user-menu-items">
                    <button class="user-menu-item user-menu-item-danger" @onclick="HandleLogout">
                        <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" />
                        <span>Çıkış Yap</span>
                    </button>
                </div>
            </MudPopover>
        </div>

        @if (_userMenuOpen)
        {
            <MudOverlay Visible="true"
                        OnClick="CloseUserMenu"
                        ZIndex="1200"
                        DarkBackground="false" />
        }
    </MudAppBar>

    @* ─── LEFT DRAWER ───────────────────────────── *@
    <MudDrawer
        @bind-Open="_drawerOpen"
        ClipMode="DrawerClipMode.Always"
        Elevation="0"
        Variant="DrawerVariant.Persistent"
        Class="sitehub-sidebar"
        Width="260px">

        <div class="sidebar-brand">
            <MudIcon Icon="@Icons.Material.Filled.Apartment" Class="brand-icon" />
            <div class="brand-text">
                <div class="brand-title">SiteHub</div>
                <div class="brand-subtitle">Yönetici Portalı</div>
            </div>
        </div>

        <NavigationMenu />

        <div class="sidebar-footer">
            <MudText Typo="Typo.caption" Style="opacity:0.6">v0.1.0 • Dev</MudText>
        </div>
    </MudDrawer>

    @* ─── MAIN CONTENT ────────────────────────── *@
    <MudMainContent Class="sitehub-main">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code {
    // Auth cookie adı (UnauthorizedResponseHandler ile aynı sabit)
    private const string AuthCookieName = ".SiteHub.Mgmt";

    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _userMenuOpen;

    // F.6 Madde 9 — bu circuit'in session identifier'ı (kendi auth cookie değeri)
    // HTTP request'ten bir kez okunur, event filter'da kullanılır
    private string? _mySessionIdentifier;

    // Dialog tek-kez açılmalı (defensive flag — event service zaten garanti veriyor)
    private bool _sessionExpiredHandled;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1E3A8A",
            Secondary = "#0EA5E9",
            Tertiary = "#F59E0B",
            Success = "#10B981",
            Info = "#3B82F6",
            Warning = "#F59E0B",
            Error = "#EF4444",

            AppbarBackground = "#FFFFFF",
            AppbarText = "#1E293B",
            DrawerBackground = "#172554",
            DrawerText = "#E0E7FF",
            DrawerIcon = "#A5B4FC",
            Background = "#F8FAFC",
            Surface = "#FFFFFF",
            TextPrimary = "#1E293B",
            TextSecondary = "#64748B",
            Divider = "#E2E8F0"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#3B82F6",
            Secondary = "#06B6D4",
            Tertiary = "#F59E0B",
            Success = "#10B981",
            Info = "#60A5FA",
            Warning = "#F59E0B",
            Error = "#F87171",

            AppbarBackground = "#0F172A",
            AppbarText = "#F1F5F9",
            DrawerBackground = "#0C1433",
            DrawerText = "#E0E7FF",
            DrawerIcon = "#A5B4FC",
            Background = "#0F172A",
            Surface = "#1E293B"
        },
        LayoutProperties = new LayoutProperties { DefaultBorderRadius = "6px" }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleUserMenu() => _userMenuOpen = !_userMenuOpen;
    private void CloseUserMenu() => _userMenuOpen = false;

    private void NavigateToTwoFactor()
    {
        _userMenuOpen = false;
        Nav.NavigateTo("/account/security/2fa");
    }

    protected override void OnInitialized()
    {
        // F.6 Madde 9 — kendi session identifier'ımızı cookie'den oku (sadece HTTP
        // initial request'te HttpContext dolu; SignalR event'lerinde boş). Initial render'da
        // kaydedip circuit boyunca tutuyoruz.
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext?.Request.Cookies.TryGetValue(AuthCookieName, out var cookieValue) == true)
        {
            _mySessionIdentifier = cookieValue;
        }

        // SessionExpired event'ine subscribe ol (Singleton — tüm circuit'ler aynı event'i dinler)
        AuthEvents.SessionExpired += OnSessionExpiredAsync;

        // Unauthenticated ise direkt login'e
        if (!CurrentUser.IsAuthenticated)
        {
            Nav.NavigateTo("/login", forceLoad: false);
        }
    }

    /// <summary>
    /// Herhangi bir circuit'in session'ı expire olduğunda tüm subscriber'lar bu event'i alır.
    /// Sadece bizim session'a ait ise dialog göster; diğer kullanıcıların 401'ine karışma.
    /// </summary>
    private async Task OnSessionExpiredAsync(SiteHub.ManagementPortal.Services.Authentication.SessionExpiredEventArgs e)
    {
        // Farklı bir kullanıcının 401'i — bize ait değil, yoksay
        if (!string.Equals(e.SessionIdentifier, _mySessionIdentifier, StringComparison.Ordinal))
            return;

        if (_sessionExpiredHandled) return;
        _sessionExpiredHandled = true;

        await InvokeAsync(async () =>
        {
            var options = new DialogOptions
            {
                BackdropClick = false,
                CloseOnEscapeKey = false,
                MaxWidth = MaxWidth.Small,
                FullWidth = true
            };

            await DialogService.ShowAsync<SiteHub.ManagementPortal.Components.Shared.Dialogs.SessionExpiredDialog>(
                title: "",
                options: options);
        });
    }

    private void OnContextChanged(Services.Contexts.ContextItem ctx)
    {
        Nav.NavigateTo("/", forceLoad: false);
    }

    private async Task HandleLogout()
    {
        _userMenuOpen = false;

        try
        {
            await JS.InvokeVoidAsync("sitehubAuth.logout");
        }
        catch { /* best-effort */ }

        Nav.NavigateTo("/login", forceLoad: true);
    }

    public async ValueTask DisposeAsync()
    {
        AuthEvents.SessionExpired -= OnSessionExpiredAsync;
        await Task.CompletedTask;
    }
}
