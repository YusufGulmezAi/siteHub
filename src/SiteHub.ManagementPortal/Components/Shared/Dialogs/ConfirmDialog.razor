@*
    Basit onay dialog'u. İki seçim: onayla / vazgeç. Reason alanı yok.

    Kullanım (ör. Deactivate):
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Message, "Bu firma pasif yapılacak. Onaylıyor musunuz?" },
            { x => x.ConfirmText, "Pasif Yap" },
            { x => x.ConfirmColor, Color.Warning }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Onay", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) { ... }

    Delete için ayrı: DeleteConfirmDialog.razor (reason zorunlu).
*@

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="py-2">@Message</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">@CancelText</MudButton>
        <MudButton Color="ConfirmColor"
                   Variant="Variant.Filled"
                   OnClick="Confirm"
                   StartIcon="@ConfirmIcon">
            @ConfirmText
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Message { get; set; } = "Devam etmek istiyor musunuz?";
    [Parameter] public string ConfirmText { get; set; } = "Onayla";
    [Parameter] public string CancelText { get; set; } = "Vazgeç";
    [Parameter] public Color ConfirmColor { get; set; } = Color.Primary;
    [Parameter] public string? ConfirmIcon { get; set; }

    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
