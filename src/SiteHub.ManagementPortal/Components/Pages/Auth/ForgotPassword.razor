@page "/forgot-password"
@layout AuthLayout
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Şifremi Unuttum — SiteHub</PageTitle>

<div class="login-grid">

    @* Sol panel — gradient + marka (Login ile aynı) *@
    <aside class="brand-pane">

        <div class="brand-logo">
            <div class="logo-mark">S</div>
            <span class="logo-text">SiteHub</span>
        </div>

        <div class="brand-copy">
            <p class="eyebrow">Mutlu yaşam</p>
            <h1 class="headline">Komşuluğun kolay yolu, yönetimin profesyonel hâli</h1>
            <p class="sub">
                Aidatından toplantısına, talebinden bakım planına —
                sitenin tüm yaşamı tek yerde, huzurla.
            </p>
        </div>

        <div class="brand-stats">
            <div class="stat">
                <div class="stat-value">1.200+</div>
                <div class="stat-label">yönetilen site</div>
            </div>
            <div class="stat">
                <div class="stat-value">48K</div>
                <div class="stat-label">mutlu sakin</div>
            </div>
            <div class="stat">
                <div class="stat-value">%99.9</div>
                <div class="stat-label">erişilebilirlik</div>
            </div>
        </div>
    </aside>

    @* Sağ panel — form *@
    <section class="form-pane">

        <div class="form-container">

            @if (!_sent)
            {
                <header class="form-header">
                    <h2>Şifremi unuttum</h2>
                    <p>Kayıtlı kullanıcı bilginizi girin, size sıfırlama bağlantısı gönderelim.</p>
                </header>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert-error">
                        @_errorMessage
                    </div>
                }

                <form @onsubmit="HandleSubmit" @onsubmit:preventDefault autocomplete="off">

                    <div class="field">
                        <label for="input">Kullanıcı bilgisi</label>
                        <input id="input"
                               type="text"
                               autocomplete="off"
                               spellcheck="false"
                               autocapitalize="off"
                               placeholder="TCKN, e-posta, telefon veya VKN"
                               @bind="_input"
                               disabled="@_isSubmitting" />
                    </div>

                    <div class="field">
                        <label>Kod gönderim yöntemi</label>
                        <div class="channel-options">
                            <label class="channel-option @(_channel == "Email" ? "is-selected" : "")">
                                <input type="radio"
                                       name="channel"
                                       value="Email"
                                       checked="@(_channel == "Email")"
                                       @onchange='() => _channel = "Email"'
                                       disabled="@_isSubmitting" />
                                <div class="channel-info">
                                    <div class="channel-title">E-posta</div>
                                    <div class="channel-sub">Kayıtlı e-posta adresinize bağlantı</div>
                                </div>
                            </label>
                            <label class="channel-option @(_channel == "Sms" ? "is-selected" : "")">
                                <input type="radio"
                                       name="channel"
                                       value="Sms"
                                       checked="@(_channel == "Sms")"
                                       @onchange='() => _channel = "Sms"'
                                       disabled="@_isSubmitting" />
                                <div class="channel-info">
                                    <div class="channel-title">SMS</div>
                                    <div class="channel-sub">Cep telefonunuza 6 haneli kod</div>
                                </div>
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="submit-btn" disabled="@_isSubmitting">
                        @if (_isSubmitting)
                        {
                            <span class="spinner"></span>
                            <span>Gönderiliyor…</span>
                        }
                        else
                        {
                            <span>Sıfırlama bağlantısı gönder</span>
                        }
                    </button>

                </form>

                <div class="form-footer">
                    <a href="/login" class="back-link">← Girişe dön</a>
                </div>
            }
            else
            {
                @* Başarılı gönderim — confirmation ekranı *@
                <div class="success-panel">
                    <div class="success-icon">✉</div>
                    <h2>Talimatlar gönderildi</h2>
                    <p>
                        Eğer kayıtlı bir hesap varsa,
                        @(_channel == "Email" ? "e-posta adresinize" : "cep telefonunuza")
                        sıfırlama talimatları gönderildi.
                    </p>
                    <p class="sub-note">
                        @if (_channel == "Email")
                        {
                            <span>Gelen kutunuzu ve spam klasörünüzü kontrol edin. Bağlantı <b>15 dakika</b> boyunca geçerli.</span>
                        }
                        else
                        {
                            <span>6 haneli kod SMS olarak gönderildi. Kod <b>15 dakika</b> boyunca geçerli.</span>
                        }
                    </p>
                    <a href="/login" class="submit-btn-link">Girişe dön</a>
                </div>
            }
        </div>

    </section>
</div>

@code {
    private string _input = "";
    private string _channel = "Email";
    private string? _errorMessage;
    private bool _isSubmitting;
    private bool _sent;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_input))
        {
            _errorMessage = "Kullanıcı bilgisi zorunludur.";
            return;
        }

        _errorMessage = null;
        _isSubmitting = true;
        StateHasChanged();

        try
        {
            var result = await JS.InvokeAsync<RequestResult>(
                "sitehubAuth.requestPasswordReset",
                _input.Trim(),
                _channel);

            if (result.Success)
            {
                _sent = true;
            }
            else
            {
                _errorMessage = result.Message ?? "İstek gönderilemedi.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Beklenmeyen bir hata oluştu.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private sealed record RequestResult(bool Success, string? Message);
}
