@page "/reset-password"
@layout AuthLayout
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Yeni Şifre — SiteHub</PageTitle>

<div class="login-grid">

    @* Sol panel — gradient *@
    <aside class="brand-pane">

        <div class="brand-logo">
            <div class="logo-mark">S</div>
            <span class="logo-text">SiteHub</span>
        </div>

        <div class="brand-copy">
            <p class="eyebrow">Mutlu yaşam</p>
            <h1 class="headline">Yeni bir başlangıç, güvenli bir devam</h1>
            <p class="sub">
                Şifrenizi sıfırladıktan sonra hesabınıza yeniden giriş yapabilirsiniz.
                Güvenliğiniz için tüm açık oturumlarınız da sonlandırılacak.
            </p>
        </div>

        <div class="brand-stats">
            <div class="stat">
                <div class="stat-value">🔒</div>
                <div class="stat-label">Uçtan uca şifreleme</div>
            </div>
            <div class="stat">
                <div class="stat-value">✓</div>
                <div class="stat-label">Tek kullanımlık bağlantı</div>
            </div>
            <div class="stat">
                <div class="stat-value">15dk</div>
                <div class="stat-label">Geçerlilik süresi</div>
            </div>
        </div>
    </aside>

    @* Sağ panel — form *@
    <section class="form-pane">

        <div class="form-container">

            @if (!_success)
            {
                <header class="form-header">
                    <h2>Yeni şifre belirle</h2>
                    <p>Yeni şifreniz en az 8 karakter, harf + rakam içermeli.</p>
                </header>

                @if (string.IsNullOrEmpty(_token))
                {
                    <div class="alert-error">
                        Geçersiz veya eksik bağlantı. Lütfen sıfırlama e-postasındaki tam bağlantıyı kullanın.
                    </div>
                    <div class="form-footer">
                        <a href="/forgot-password" class="back-link">← Yeni talep oluştur</a>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert-error">
                            @_errorMessage
                        </div>
                    }

                    <form @onsubmit="HandleSubmit" @onsubmit:preventDefault autocomplete="off">

                        <div class="field">
                            <label for="newpassword">Yeni şifre</label>
                            <input id="newpassword"
                                   type="password"
                                   autocomplete="new-password"
                                   placeholder="En az 8 karakter, harf + rakam"
                                   @bind="_newPassword"
                                   disabled="@_isSubmitting" />
                        </div>

                        <div class="field">
                            <label for="confirm">Yeni şifre (tekrar)</label>
                            <input id="confirm"
                                   type="password"
                                   autocomplete="new-password"
                                   placeholder="Yeni şifreyi tekrar girin"
                                   @bind="_confirmPassword"
                                   disabled="@_isSubmitting" />
                        </div>

                        <button type="submit" class="submit-btn" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <span class="spinner"></span>
                                <span>Kaydediliyor…</span>
                            }
                            else
                            {
                                <span>Şifreyi sıfırla</span>
                            }
                        </button>

                    </form>

                    <div class="form-footer">
                        <a href="/login" class="back-link">← Girişe dön</a>
                    </div>
                }
            }
            else
            {
                <div class="success-panel">
                    <div class="success-icon">✓</div>
                    <h2>Şifreniz değiştirildi</h2>
                    <p>
                        Yeni şifrenizle giriş yapabilirsiniz. Güvenliğiniz için
                        tüm aktif oturumlarınız kapatıldı.
                    </p>
                    <a href="/login" class="submit-btn-link">Girişe git</a>
                </div>
            }
        </div>

    </section>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? TokenFromQuery { get; set; }

    private string _token = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    private string? _errorMessage;
    private bool _isSubmitting;
    private bool _success;

    protected override void OnInitialized()
    {
        _token = TokenFromQuery ?? "";
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(_token))
        {
            _errorMessage = "Bağlantı token'ı bulunamadı.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword) || string.IsNullOrWhiteSpace(_confirmPassword))
        {
            _errorMessage = "Her iki şifre alanı da zorunludur.";
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _errorMessage = "Şifreler eşleşmiyor.";
            return;
        }

        if (_newPassword.Length < 8)
        {
            _errorMessage = "Şifre en az 8 karakter olmalı.";
            return;
        }

        _errorMessage = null;
        _isSubmitting = true;
        StateHasChanged();

        try
        {
            var result = await JS.InvokeAsync<ResetResult>(
                "sitehubAuth.resetPassword",
                _token,
                _newPassword);

            if (result.Success)
            {
                _success = true;
            }
            else
            {
                _errorMessage = result.Message ?? "Şifre sıfırlanamadı.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Beklenmeyen bir hata oluştu.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private sealed record ResetResult(bool Success, string? Code, string? Message);
}
