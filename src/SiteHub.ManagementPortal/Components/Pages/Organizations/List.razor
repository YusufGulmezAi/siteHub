@page "/organizations"
@rendermode InteractiveServer

@using SiteHub.Contracts.Common
@using SiteHub.Contracts.Organizations
@using SiteHub.ManagementPortal.Services.Api
@using SiteHub.ManagementPortal.Components.Shared
@using SiteHub.Domain.Identity.Authorization
@using SiteHub.Shared.Authorization
@using SiteHub.ManagementPortal.Components.Shared.Authorization

@inject IOrganizationsApi OrganizationsApi
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Yönetim Firmaları — SiteHub</PageTitle>

@*
    F.6 Kategori A düzeltmeleri:
      Madde 1: "Yönetim firmaları (Organization)..." alt metni silindi.
      Madde 2: Başlık "Organizasyonlar" → "Yönetim Firmaları".
      Madde 3: Aktif badge koyu yeşil + beyaz (success-darken, Site List ile tutarlı).
*@
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <div>
        <MudText Typo="Typo.h4" Style="font-weight:600">Yönetim Firmaları</MudText>
    </div>
    <MudSpacer />
    <HasPermission Required="@Permissions.Organization.Create"
                   ContextType="MembershipContextType.System">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="NavigateToCreate">
            Yeni Yönetim Firması
        </MudButton>
    </HasPermission>
</MudStack>

<MudPaper Elevation="1" Class="pa-4">

    @* Arama — DataGrid toolbar'ından ayrı kalır (header'ın üstünde) *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
        <MudTextField T="string"
                      Value="_search"
                      ValueChanged="OnSearchChanged"
                      Placeholder="İsim, VKN, e-posta ile ara..."
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      DebounceInterval="300"
                      Immediate="true"
                      Clearable="true"
                      Style="max-width:420px" />
    </MudStack>

    <SiteHubDataGrid T="OrganizationListItemDto"
                     ServerData="LoadServerData"
                     @ref="_grid">
        <ToolBarContent>
            @* Kategori A Madde A-b: Aktif/Pasif switch DataGrid toolbar'ında (solda).
               Dişli ikonu (ShowMenuIcon) MudSpacer sayesinde tablonun sağ ucuna konur. *@
            <MudSwitch T="bool" @bind-Value="_onlyActive"
                       @bind-Value:after="RefreshAsync"
                       Color="Color.Primary"
                       Label="@(_onlyActive ? "Aktif" : "Hepsi")" />
            <MudSpacer />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Code" Title="Kod" />
            <PropertyColumn Property="x => x.Name" Title="Ad" />
            <PropertyColumn Property="x => x.CommercialTitle" Title="Ticari Ünvan" />
            <PropertyColumn Property="x => x.TaxId" Title="VKN" />
            <PropertyColumn Property="x => x.Phone" Title="Telefon" />
            <PropertyColumn Property="x => x.Email" Title="E-posta" />
            <TemplateColumn Title="Durum" Sortable="false" Filterable="false">
                <CellTemplate>
                    @* Madde 3: Aktif koyu yeşil + beyaz (Site List ile aynı) *@
                    @if (context.Item.IsActive)
                    {
                        <div style="display: inline-flex; align-items: center; padding: 2px 10px;
                                    border-radius: 999px; background-color: var(--mud-palette-success-darken);
                                    color: #ffffff; font-size: 0.75rem;
                                    font-weight: 500; line-height: 1.2;">
                            Aktif
                        </div>
                    }
                    else
                    {
                        <div style="display: inline-flex; align-items: center; padding: 2px 10px;
                                    border-radius: 999px; background-color: transparent;
                                    border: 1px solid var(--mud-palette-action-disabled);
                                    color: var(--mud-palette-text-secondary); font-size: 0.75rem;
                                    font-weight: 500; line-height: 1.2;">
                            Pasif
                        </div>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="İşlemler" Sortable="false" Filterable="false">
                <CellTemplate>
                    <MudTooltip Text="Detay">
                        <HasPermission Required="@Permissions.Organization.Read"
                                       ContextType="MembershipContextType.Organization"
                                       ContextId="@context.Item.Id">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => NavigateToDetail(context.Item.Id))"
                                           aria-label="Detay" />
                        </HasPermission>
                    </MudTooltip>

                    <MudTooltip Text="Düzenle">
                        <HasPermission Required="@Permissions.Organization.Update"
                                       ContextType="MembershipContextType.Organization"
                                       ContextId="@context.Item.Id">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Default"
                                           OnClick="@(() => NavigateToEdit(context.Item.Id))"
                                           aria-label="Düzenle" />
                        </HasPermission>
                    </MudTooltip>

                    <MudTooltip Text="Siteler">
                        <HasPermission Required="@Permissions.Site.Read"
                                       ContextType="MembershipContextType.Organization"
                                       ContextId="@context.Item.Id">
                            <MudIconButton Icon="@Icons.Material.Filled.Apartment"
                                           Size="Size.Small"
                                           Color="Color.Default"
                                           OnClick="@(() => NavigateToSites(context.Item.Id))"
                                           aria-label="Siteler" />
                        </HasPermission>
                    </MudTooltip>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="ma-4">
                Gösterilecek organizasyon yok.
                @if (!string.IsNullOrWhiteSpace(_search))
                {
                    <span> Arama kriterlerinizi gevşetin.</span>
                }
            </MudAlert>
        </NoRecordsContent>
    </SiteHubDataGrid>
</MudPaper>

@code {
    private SiteHubDataGrid<OrganizationListItemDto>? _grid;
    private string? _search;
    private bool _onlyActive = true;

    private async Task<GridData<OrganizationListItemDto>> LoadServerData(
        GridState<OrganizationListItemDto> state, CancellationToken ct)
    {
        try
        {
            var result = await OrganizationsApi.GetAllAsync(
                page: state.Page + 1,
                pageSize: state.PageSize,
                search: string.IsNullOrWhiteSpace(_search) ? null : _search,
                includeInactive: !_onlyActive,
                ct: ct);

            return new GridData<OrganizationListItemDto>
            {
                Items = result.Items,
                TotalItems = result.TotalCount
            };
        }
        catch (OperationCanceledException)
        {
            return new GridData<OrganizationListItemDto>
            {
                Items = Array.Empty<OrganizationListItemDto>(),
                TotalItems = 0
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Organizasyonlar yüklenemedi: {ex.Message}", Severity.Error);
            return new GridData<OrganizationListItemDto>
            {
                Items = Array.Empty<OrganizationListItemDto>(),
                TotalItems = 0
            };
        }
    }

    private async Task OnSearchChanged(string? value)
    {
        _search = value;
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        if (_grid is not null)
            await _grid.ReloadAsync();
    }

    private void NavigateToCreate() => Nav.NavigateTo("/organizations/new");
    private void NavigateToDetail(Guid id) => Nav.NavigateTo($"/organizations/{id}");
    private void NavigateToEdit(Guid id) => Nav.NavigateTo($"/organizations/{id}/edit");
    private void NavigateToSites(Guid id) => Nav.NavigateTo($"/organizations/{id}/sites");
}
