{
  "ConnectionStrings": {
    "__comment": "Gerçek değerler .env dosyasından ConnectionStrings__Postgres env var'ı ile sağlanır. Bu varsayılan sadece .env olmadığında devreye girer — PROD'DA KULLANMA.",
    "Postgres": "",
    "Redis": ""
  },
  "Email": {
    "__comment": "MailHog docker'da (localhost:1025). UI: http://localhost:8025. Prod'da SendGrid/AWS SES/vb.",
    "Host": "localhost",
    "Port": 1025,
    "UseSsl": false,
    "Username": null,
    "Password": null,
    "FromAddress": "noreply@sitehub.local",
    "FromName": "SiteHub"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
