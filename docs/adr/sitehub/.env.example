# ═══════════════════════════════════════════════════════════════════════════════
# SiteHub — Environment Variables
#
# BU DOSYAYI '.env' OLARAK KOPYALA VE KENDİ DEĞERLERİNLE DOLDUR.
# '.env' dosyası git'e COMMIT EDİLMEZ (.gitignore'da listeli).
#
# Kurulum: cp .env.example .env
# Sonra:   ./scripts/dev-infra.ps1 setup
# ═══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=sitehub
POSTGRES_USER=sitehub
POSTGRES_PASSWORD=sitehub_dev_pw_change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Host makinede expose edilen port. Çakışma varsa burayı değiştir (örn: 15432).
POSTGRES_HOST_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=sitehub_dev_pw_change_me
REDIS_HOST=localhost
REDIS_PORT=6379
# Host port — Memurai/başka Redis varsa değiştir (örn: 16379)
REDIS_HOST_PORT=6379

# ─── MinIO (S3-uyumlu dosya depolama) ────────────────────────────────────────
MINIO_ROOT_USER=sitehub
MINIO_ROOT_PASSWORD=sitehub_dev_pw_change_me
MINIO_HOST_PORT_API=9000
MINIO_HOST_PORT_CONSOLE=9001

# ─── Seq (structured log viewer) ─────────────────────────────────────────────
SEQ_HOST_PORT=5341

# ─── MailHog (SMTP test server) ──────────────────────────────────────────────
MAILHOG_HOST_PORT_SMTP=1025
MAILHOG_HOST_PORT_UI=8025

# ─── pgAdmin (PostgreSQL yönetim arayüzü) ────────────────────────────────────
# NOT: Email 'admin@sitehub.local' KULLANMA — pgAdmin 8+ "special-use" domain olarak
# reddediyor (RFC 6761). example.com veya gerçek bir domain kullan.
PGADMIN_DEFAULT_EMAIL=admin@sitehub.example
PGADMIN_DEFAULT_PASSWORD=sitehub_dev_pw_change_me
PGADMIN_HOST_PORT=5050

# ─── .NET Application Settings ───────────────────────────────────────────────
# ASP.NET Core bu env var'ları otomatik okur. "__" alt-bölüm ayracıdır.
# Örn: ConnectionStrings__Postgres → appsettings'teki "ConnectionStrings:Postgres"

ConnectionStrings__Postgres=Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};Include Error Detail=true;
ConnectionStrings__Redis=${REDIS_HOST}:${REDIS_PORT},password=${REDIS_PASSWORD}

# ─── Environment ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# ─── Logging ─────────────────────────────────────────────────────────────────
Serilog__WriteTo__1__Args__serverUrl=http://localhost:5341

# ─── Production Override'ları (prod'da bu dosya kullanılmaz — secret manager) ─
# Production'da .env DEĞİL, environment variable veya Azure Key Vault / AWS Secrets
# Manager / HashiCorp Vault gibi bir secret store kullanılır. Detay: ADR-0008
