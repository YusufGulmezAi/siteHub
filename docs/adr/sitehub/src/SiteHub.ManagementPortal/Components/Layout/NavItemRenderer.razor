@using SiteHub.ManagementPortal.Components.Navigation

@if (Item.HasChildren)
{
    // @if { ... } bloğu zaten kod bağlamında — @{ ... } gerekmez.
    var visibleChildren = HasSearch
        ? Item.Children.Where(c => c.Matches(Search)).ToList()
        : Item.Children;

    <MudNavGroup Title="@Item.Title" Icon="@Item.Icon" Expanded="@HasSearch">
        @foreach (var child in visibleChildren)
        {
            <NavItemRenderer Item="child" />
        }
    </MudNavGroup>
}
else if (!string.IsNullOrEmpty(Item.Href))
{
    <MudNavLink Href="@Item.Href" Icon="@Item.Icon" Match="NavLinkMatch.All">
        @Item.Title
    </MudNavLink>
}

@code {
    [Parameter, EditorRequired] public required MenuItem Item { get; set; }

    [CascadingParameter(Name = "MenuSearch")]
    public string? Search { get; set; }

    private bool HasSearch => !string.IsNullOrWhiteSpace(Search);
}
