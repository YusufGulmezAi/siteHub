@page "/Error"
@using System.Diagnostics

<PageTitle>Hata</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-16">
    <MudPaper Class="pa-8" Elevation="4">
        <MudText Typo="Typo.h3" Color="Color.Error" GutterBottom="true">
            Bir hata oluştu
        </MudText>

        <MudText Typo="Typo.body1" Class="mb-4">
            İsteğiniz işlenirken bir sorunla karşılaşıldı. Sorun devam ederse lütfen
            destek ekibine bildirin.
        </MudText>

        @if (ShowRequestId)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                <strong>Request ID:</strong> <code>@RequestId</code>
            </MudAlert>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">
            Ana Sayfa'ya dön
        </MudButton>
    </MudPaper>
</MudContainer>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
